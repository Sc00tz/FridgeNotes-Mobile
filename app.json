{
  "expo": {
    "name": "FridgeNotes",
    "slug": "fridgenotes-mobile",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "fridgenotes",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fridgenotes.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "FridgeNotes uses notifications to remind you about notes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "package": "com.fridgenotes.app",
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "autoVerify": false,
          "data": [
            {
              "mimeType": "text/plain"
            },
            {
              "mimeType": "text/*"
            }
          ],
          "category": [
            "android.intent.category.DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3b82f6",
          "defaultChannel": "reminders",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-audio",
        {
          "microphonePermission": "FridgeNotes uses the microphone to record voice memos on notes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FridgeNotes accesses your photos so you can attach images to notes.",
          "cameraPermission": "FridgeNotes uses the camera so you can attach photos to notes."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FridgeNotes uses your location to set location-based reminders."
        }
      ],
      "./plugins/withReleaseSigning.js",
      "expo-asset"
    ],
    "extra": {
      "apiUrl": "http://192.168.66.73:5009",
      "eas": {
        "projectId": "25bd1647-e911-4966-a5e7-9f2e1e40b7ee"
      }
    },
    "owner": "sc00ter"
  }
}
